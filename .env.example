# Copy to .env and adjust if needed:
#   cp .env.example .env
#
# Docker Compose reads this file automatically for ${VAR} substitution.
# The API container also receives these values via env_file (when .env exists).

# PostgreSQL (docker compose service: postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hotels
POSTGRES_PORT=5432

# API (docker compose service: api)
API_PORT=8080

# Optional for local dev: protect POST/PUT/DELETE with X-Api-Key (leave empty to disable writes auth)
# Required when ASPNETCORE_ENVIRONMENT=Production — the API fails startup without a write key
# ApiKey__WriteKey=change-me-in-production

# Used by Docker Compose for the api service (host name "postgres" = service name)
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=hotels;Username=postgres;Password=postgres

# Local dotnet run — override when PostgreSQL runs on localhost:
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=hotels;Username=postgres;Password=postgres
# ApiKey__WriteKey=local-dev-write-key
